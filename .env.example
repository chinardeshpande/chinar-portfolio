# ===========================================
# Portfolio Environment Variables
# ===========================================

# NextAuth Configuration
NEXTAUTH_URL=https://chinardeshpande.tech
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password

# Google OAuth (for Analytics & Search Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Google Analytics 4
GA4_PROPERTY_ID=your-ga4-property-id

# Google Search Console
SEARCH_CONSOLE_SITE_URL=https://chinardeshpande.tech

# ===========================================
# How to Generate Values
# ===========================================

# NEXTAUTH_SECRET:
#   openssl rand -base64 32

# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REFRESH_TOKEN:
#   Run: node setup-analytics-auth.js
#   Follow the prompts

# GA4_PROPERTY_ID:
#   Google Analytics → Admin → Property Settings → Property ID

# ===========================================
# Local Development
# ===========================================
# For local testing, create .env.local with these values
# Never commit .env.local to git!
